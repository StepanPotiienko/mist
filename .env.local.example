# ── Security ──────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=replace_with_32_byte_hex_string

# ── Remote / multi-device access ──────────────────────────────────────────────
# The public-facing URL where Mist is reachable.
# Controls the OAuth redirect URIs (GOOGLE_REDIRECT_URI, NOTION_REDIRECT_URI)
# and Next.js server-side URL (NEXTAUTH_URL) — update all three together.
#
# Single-machine (default):
#   BASE_URL=http://localhost:3131
#
# LAN access from other devices on your network:
#   BASE_URL=http://192.168.1.100:3131
#
# Raspberry Pi / always-on server via Tailscale VPN (recommended for remote):
#   BASE_URL=http://100.64.0.1:3131
#
# Custom domain with HTTPS (required for some OAuth providers in production):
#   BASE_URL=https://mist.yourdomain.com
BASE_URL=http://localhost:3131

# ── Notion ─────────────────────────────────────────────────────────────────────
NOTION_API_KEY=secret_...
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
# Update to match BASE_URL when deploying remotely.
# Must also be registered in your Notion integration's redirect URI list.
NOTION_REDIRECT_URI=http://localhost:3131/api/auth/notion

# ── Google Calendar ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Update to match BASE_URL when deploying remotely.
# Must exactly match the Authorized Redirect URI in Google Cloud Console.
GOOGLE_REDIRECT_URI=http://localhost:3131/api/auth/google

# ── Obsidian Local REST API ─────────────────────────────────────────────────────
# The URL of the Obsidian Local REST API plugin.
#
# Local dev (non-Docker): http://localhost:27123
# Docker, Obsidian on the same host: leave blank — docker-compose.yml sets
#   this to http://host.docker.internal:27123 automatically.
# Docker on a separate device (Pi) while Obsidian runs on your Mac:
#   set this in a Docker Compose .env file (not .env.local) to your Mac's address:
#   OBSIDIAN_API_URL=http://192.168.1.5:27123
#   OBSIDIAN_API_URL=http://100.64.0.5:27123   # via Tailscale
OBSIDIAN_API_URL=http://localhost:27123

# ── Database ───────────────────────────────────────────────────────────────────
# Dev path — docker-compose.yml overrides this to /data/mist.db inside the container.
DATABASE_URL=file:./prisma/dev.db

# ── Next.js ────────────────────────────────────────────────────────────────────
# Must match BASE_URL above.
NEXTAUTH_URL=http://localhost:3131
NEXTAUTH_SECRET=replace_with_random_secret
