generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Credential {
  id        String   @id @default(cuid())
  service   String   @unique // "notion" | "google" | "apple" | "obsidian"
  data      String // JSON blob, AES-256 encrypted
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Link {
  id         String   @id @default(cuid())
  sourceType String // "obsidian" | "notion" | "apple" | "google"
  sourceId   String // note path / notion page id / event uid
  targetType String
  targetId   String
  createdAt  DateTime @default(now())

  @@unique([sourceType, sourceId, targetType, targetId])
  @@index([sourceType, sourceId])
  @@index([targetType, targetId])
}

model WidgetLayout {
  id        String   @id @default(cuid())
  pageSlug  String   @unique // e.g. "workspace-default"
  layout    String // JSON: react-grid-layout LayoutItem[]
  updatedAt DateTime @updatedAt
}

model WorkspacePage {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  icon      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}
